{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the Truekio app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "reputation": { "type": "number" },
        "verified": { "type": "boolean" },
        "tradeScore": { "type": "number" },
        "fcmToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Item": {
      "title": "Item",
      "description": "An item listed for trade",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "condition": { "type": "string", "enum": ["new", "like-new", "good", "fair"] },
        "category": { "type": "string" },
        "lookingFor": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "trading", "traded"] },
        "isAuction": { "type": "boolean" },
        "auctionEndsAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "title", "description", "imageUrl", "condition", "category", "status", "createdAt"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A trade offer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetItemId": { "type": "string" },
        "targetOwnerId": { "type": "string" },
        "offererId": { "type": "string" },
        "offeredItemId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "targetItemId", "targetOwnerId", "offererId", "offeredItemId", "status", "createdAt"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "A user's trade evolution challenge",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "history": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "history", "status", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat room between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "senderId", "text", "createdAt"]
    },
    "CallSignal": {
      "title": "CallSignal",
      "description": "WebRTC signaling data",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "senderId": { "type": "string" },
        "data": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "senderId", "data", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/items/{itemId}": {
      "schema": { "$ref": "#/entities/Item" },
      "description": "Items available for trade"
    },
    "/trades/{tradeId}": {
      "schema": { "$ref": "#/entities/Trade" },
      "description": "Trade offers between users"
    },
    "/challenges/{challengeId}": {
      "schema": { "$ref": "#/entities/Challenge" },
      "description": "User trade challenges"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat rooms"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages in a chat"
    },
    "/chats/{chatId}/signals/{signalId}": {
      "schema": { "$ref": "#/entities/CallSignal" },
      "description": "WebRTC signals for a chat"
    }
  }
}

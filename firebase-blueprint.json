{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the Truekio app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "reputation": { "type": "number" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Item": {
      "title": "Item",
      "description": "An item listed for trade",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "condition": { "type": "string", "enum": ["new", "like-new", "good", "fair"] },
        "lookingFor": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "trading", "traded"] },
        "isAuction": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "title", "description", "imageUrl", "condition", "status", "createdAt"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A trade offer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetItemId": { "type": "string" },
        "targetOwnerId": { "type": "string" },
        "offererId": { "type": "string" },
        "offeredItemId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "targetItemId", "targetOwnerId", "offererId", "offeredItemId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/items/{itemId}": {
      "schema": { "$ref": "#/entities/Item" },
      "description": "Items available for trade"
    },
    "/trades/{tradeId}": {
      "schema": { "$ref": "#/entities/Trade" },
      "description": "Trade offers between users"
    }
  }
}

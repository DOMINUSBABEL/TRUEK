rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             (!('location' in data) || (data.location is string && data.location.size() <= 100)) &&
             (!('reputation' in data) || data.reputation is number) &&
             (!('verified' in data) || data.verified is bool) &&
             (!('tradeScore' in data) || data.tradeScore is number) &&
             (!('fcmToken' in data) || data.fcmToken is string) &&
             data.createdAt is string;
    }

    function isValidItem(data) {
      return data.id is string && data.id.size() > 0 &&
             data.ownerId is string && data.ownerId.size() > 0 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 1000 &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.condition in ['new', 'like-new', 'good', 'fair'] &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             (!('lookingFor' in data) || (data.lookingFor is string && data.lookingFor.size() <= 200)) &&
             (!('location' in data) || (data.location is string && data.location.size() <= 100)) &&
             data.status in ['available', 'trading', 'traded'] &&
             (!('isAuction' in data) || data.isAuction is bool) &&
             (!('auctionEndsAt' in data) || data.auctionEndsAt is string) &&
             data.createdAt is string;
    }

    function isValidTrade(data) {
      return data.id is string && data.id.size() > 0 &&
             data.targetItemId is string && data.targetItemId.size() > 0 &&
             data.targetOwnerId is string && data.targetOwnerId.size() > 0 &&
             data.offererId is string && data.offererId.size() > 0 &&
             data.offeredItemId is string && data.offeredItemId.size() > 0 &&
             data.status in ['pending', 'accepted', 'rejected', 'completed'] &&
             data.createdAt is string;
    }

    function isValidChallenge(data) {
      return data.id is string && data.id.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.history is list && data.history.size() > 0 &&
             data.status in ['active', 'completed'] &&
             data.createdAt is string;
    }

    function isValidChat(data) {
      return data.id is string && data.id.size() > 0 &&
             data.participants is list && data.participants.size() == 2 &&
             (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() <= 1000)) &&
             data.updatedAt is string;
    }

    function isValidMessage(data) {
      return data.id is string && data.id.size() > 0 &&
             data.chatId is string && data.chatId.size() > 0 &&
             data.senderId is string && data.senderId.size() > 0 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 2000 &&
             data.createdAt is string;
    }

    function isValidCallSignal(data) {
      return data.type in ['offer', 'answer', 'candidate'] &&
             data.senderId is string && data.senderId.size() > 0 &&
             data.data is string && data.data.size() > 0 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && hasRequiredFields(['uid', 'displayName', 'email', 'createdAt']) && isValidUser(request.resource.data) && uidUnchanged() && !('reputation' in request.resource.data) && !('verified' in request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && (!('reputation' in request.resource.data) || request.resource.data.reputation == resource.data.reputation) && (!('verified' in request.resource.data) || request.resource.data.verified == resource.data.verified);
    }

    match /items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ownerId && hasRequiredFields(['id', 'ownerId', 'title', 'description', 'imageUrl', 'condition', 'category', 'status', 'createdAt']) && isValidItem(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.ownerId && isValidItem(request.resource.data) && request.resource.data.ownerId == resource.data.ownerId;
    }

    match /trades/{tradeId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.offererId || request.auth.uid == resource.data.targetOwnerId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.offererId && hasRequiredFields(['id', 'targetItemId', 'targetOwnerId', 'offererId', 'offeredItemId', 'status', 'createdAt']) && isValidTrade(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.offererId || request.auth.uid == resource.data.targetOwnerId) && isValidTrade(request.resource.data) && request.resource.data.offererId == resource.data.offererId && request.resource.data.targetOwnerId == resource.data.targetOwnerId;
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && hasRequiredFields(['id', 'userId', 'history', 'status', 'createdAt']) && isValidChallenge(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && isValidChallenge(request.resource.data) && request.resource.data.userId == resource.data.userId;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants && hasRequiredFields(['id', 'participants', 'updatedAt']) && isValidChat(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidChat(request.resource.data) && request.resource.data.participants == resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && hasRequiredFields(['id', 'chatId', 'senderId', 'text', 'createdAt']) && isValidMessage(request.resource.data);
      }

      match /signals/{signalId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && hasRequiredFields(['type', 'senderId', 'data', 'createdAt']) && isValidCallSignal(request.resource.data);
        allow delete: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
